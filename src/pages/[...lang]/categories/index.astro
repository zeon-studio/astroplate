---
import Base from "@/layouts/Base.astro";
import { getAllTaxonomy, getTaxonomy } from "@/lib/taxonomyParser.astro";
import {
  getTranslations,
  normalizeLang,
  slugSelector,
  supportedLang,
} from "@/lib/utils/languageParser";
import { humanize } from "@/lib/utils/textConverter";
import PageHeader from "@/partials/PageHeader.astro";

const BLOG_FOLDER = "blog";

export function getStaticPaths() {
  return supportedLang.map((lang) => ({
    params: { lang: lang || undefined },
  }));
}

const lang = normalizeLang(Astro.params.lang);
const categories = await getTaxonomy(BLOG_FOLDER, lang, "categories");
const allCategories = await getAllTaxonomy(BLOG_FOLDER, lang, "categories");
const { categories: categoriesLabel } = (await getTranslations(lang)) as unknown as {
  categories: string;
};
---

<Base title={categoriesLabel} lang={lang}>
  <PageHeader title={categoriesLabel} />
  <section class="section">
    <div class="container text-center">
      <ul>
        {
          categories.map((category: string) => {
            const count = allCategories.filter((c) => c === category).length;
            return (
              <li class="m-3 inline-block">
                <a
                  href={slugSelector(`/categories/${category}`, lang)}
                  class="block rounded bg-light px-4 py-2 text-xl text-text-dark dark:bg-darkmode-light dark:text-darkmode-text-dark"
                >
                  {humanize(category)}{" "}
                  <span class="ml-2 rounded bg-body px-2 dark:bg-darkmode-body">
                    {count}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</Base>
