---
import AuthorCard from "@/components/AuthorCard.astro";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import { normalizeLang, supportedLang } from "@/lib/utils/languageParser";
import PageHeader from "@/partials/PageHeader.astro";

export function getStaticPaths() {
  return supportedLang.map((lang) => ({
    params: { lang: lang || undefined },
  }));
}

const lang = normalizeLang(Astro.params.lang);
const authorIndex = await getListPage("authors", lang, "-index");

if (authorIndex.data.draft) {
  return Astro.redirect("/404");
}

const authors = await getSinglePage("authors", lang);
---

<Base title={authorIndex.data.title} lang={lang}>
  <PageHeader title={authorIndex.data.title} />
  <section class="section-sm pb-0">
    <div class="container">
      <div class="row justify-center">
        {
          authors.map((author) => (
            <div class="mb-14 md:col-6 lg:col-4">
              <AuthorCard data={author} />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
