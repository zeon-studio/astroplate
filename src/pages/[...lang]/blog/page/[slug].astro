---
import config from "@/config/config.json";
import { getSinglePage } from "@/lib/contentParser.astro";
import {
  normalizeLang,
  slugSelector,
  supportedLang,
} from "@/lib/utils/languageParser";

export async function getStaticPaths() {
  const BLOG_FOLDER = "blog";
  const paths = [];

  for (const routeLang of supportedLang) {
    const lang = normalizeLang(routeLang);
    const posts = await getSinglePage(BLOG_FOLDER, lang);
    const totalPages = Math.ceil(posts.length / config.settings.pagination);

    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: {
          lang: routeLang || undefined,
          slug: page.toString(),
        },
      });
    }
  }

  return paths;
}

return Astro.redirect(
  slugSelector(`/page/${Astro.params.slug}`, normalizeLang(Astro.params.lang)),
  301,
);
---
