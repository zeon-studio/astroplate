---
import Base from "@/layouts/Base.astro";
import { adaptPosts } from "@/lib/emdashAdapter";
import { humanize, slugify } from "@/lib/utils/textConverter";
import PageHeader from "@/partials/PageHeader.astro";
import { getEmDashCollection } from "emdash";

const { entries } = await getEmDashCollection("posts", { status: "published" });
const allPosts = adaptPosts(entries ?? []);

// Collect all category slugs from JSON field on each post
const allCategories: string[] = allPosts.flatMap((p) =>
  p ? (p.data.categories as string[]).map(slugify) : [],
);
const categories = [...new Set(allCategories)];
---

<Base title={"Categories"}>
  <PageHeader title={"Categories"} />
  <section class="section">
    <div class="container text-center">
      <ul>
        {
          categories.map((category: string) => {
            const count = allCategories.filter((c) => c === category).length;
            return (
              <li class="m-3 inline-block">
                <a
                  href={`/categories/${category}`}
                  class="block rounded bg-light px-4 py-2 text-xl text-text-dark dark:bg-darkmode-light dark:text-darkmode-text-dark"
                >
                  {humanize(category)}{" "}
                  <span class="ml-2 rounded bg-body px-2 dark:bg-darkmode-body">
                    {count}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</Base>
