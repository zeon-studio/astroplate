---
import BlogCard from "@/components/BlogCard.astro";
import Base from "@/layouts/Base.astro";
import { adaptPosts } from "@/lib/emdashAdapter";
import { sortByDate } from "@/lib/utils/sortFunctions";
import { slugify } from "@/lib/utils/textConverter";
import PageHeader from "@/partials/PageHeader.astro";
import { getEmDashCollection } from "emdash";

export const prerender = false;

const { category } = Astro.params;

let posts: any[] = [];
try {
  const { entries } = await getEmDashCollection("posts", {
    status: "published",
  });
  if (entries) {
    // categories are stored as a JSON array on each post — filter manually
    posts = adaptPosts(entries).filter(
      (p) =>
        p !== null &&
        (p.data.categories as string[]).map(slugify).includes(category!),
    );
  }
} catch (e) {}

const sortedPosts = sortByDate(posts);
const categoryLabel = category ? category.replace(/-/g, " ") : "";
---

<Base title={categoryLabel}>
  <PageHeader title={categoryLabel} />
  <div class="section-sm pb-0">
    <div class="container">
      <div class="row">
        {
          sortedPosts.map((post) => (
            <div class="mb-14 md:col-6 lg:col-4">
              <BlogCard data={post} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Base>
