---
import Base from "@/layouts/Base.astro";
import PostSingle from "@/layouts/PostSingle.astro";
import { adaptPost } from "@/lib/emdashAdapter";
import { getEmDashEntry } from "emdash";

export const prerender = false;

const { single } = Astro.params;

const { entry, error, isPreview } = await getEmDashEntry("posts", single!);

if (error) {
  return new Response("Server error", { status: 500 });
}

if (!entry) {
  return Astro.redirect("/404");
}

const post = adaptPost(entry)!;
const { title, meta_title, description, image } = post.data;
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {
    isPreview && (
      <div class="bg-yellow-100 border-l-4 border-yellow-500 p-3 text-sm text-yellow-800 text-center">
        You are viewing a preview — this content is not yet published.
      </div>
    )
  }
  <PostSingle post={post} />
</Base>
