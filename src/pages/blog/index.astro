---
import BlogCard from "@/components/BlogCard.astro";
import Pagination from "@/components/Pagination.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { adaptPost, adaptPosts } from "@/lib/emdashAdapter";
import { getAllTaxonomy, getTaxonomy } from "@/lib/taxonomyParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import PageHeader from "@/partials/PageHeader.astro";
import PostSidebar from "@/partials/PostSidebar.astro";
import { getEmDashCollection, getEmDashEntry } from "emdash";

const BLOG_FOLDER = "blog";

// Fetch index metadata from EmDash or fallback to filesystem
let postIndex;
try {
  const { entry: emIndex } = await getEmDashEntry("pages", "blog");
  if (emIndex) {
    postIndex = adaptPost(emIndex);
  }
} catch (e) {
  console.log("EmDash blog index loading failed:", e);
}

if (!postIndex) {
  postIndex = await getListPage(BLOG_FOLDER, "-index");
}

if (postIndex.data.draft) {
  return Astro.redirect("/404");
}

let posts: any[] = [];
let emCategories: string[] = [];
let emTags: string[] = [];

try {
  const { entries } = await getEmDashCollection("posts", {
    status: "published",
  });
  if (entries) {
    posts = adaptPosts(entries);
    // Extract unique categories and tags from EmDash posts
    emCategories = [...new Set(posts.flatMap((p) => p.data.categories))].filter(
      Boolean,
    );
    emTags = [...new Set(posts.flatMap((p) => p.data.tags))].filter(Boolean);
  }
} catch (e) {
  console.log("EmDash posts loading failed:", e);
}

// Fallback to filesystem if EmDash is empty or fails
const allCategories =
  emCategories.length > 0
    ? emCategories
    : await getAllTaxonomy(BLOG_FOLDER, "categories");
const categories =
  emCategories.length > 0
    ? emCategories
    : await getTaxonomy(BLOG_FOLDER, "categories");
const tags =
  emTags.length > 0 ? emTags : await getTaxonomy(BLOG_FOLDER, "tags");
const sortedPosts = sortByDate(posts);
const totalPages: number = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
---

<Base
  title={postIndex.data.title}
  meta_title={postIndex.data.meta_title}
  image={postIndex.data.image}
  description={postIndex.data.description}
>
  <PageHeader title={postIndex?.data.title} />
  <section class="section">
    <div class="container">
      <div class="row gx-5">
        <!-- blog posts -->
        <div class="lg:col-8">
          <div class="row">
            {
              currentPosts.map((post) => (
                <div class="mb-14 md:col-6">
                  <BlogCard data={post} />
                </div>
              ))
            }
          </div>
          <Pagination
            section={BLOG_FOLDER}
            currentPage={1}
            totalPages={totalPages}
          />
        </div>

        <!-- sidebar -->
        <PostSidebar
          categories={categories}
          tags={tags}
          allCategories={allCategories}
        />
      </div>
    </div>
  </section>
</Base>
