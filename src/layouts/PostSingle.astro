---
import BlogCard from "@/components/BlogCard.astro";
import Share from "@/components/Share.astro";
import config from "@/config/config.json";
import Disqus from "@/helpers/Disqus";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { slugSelector } from "@/lib/utils/languageParser";
import similarItems from "@/lib/utils/similarItems";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { render, type ContentEntryMap } from "astro:content";
import { FaRegClock, FaRegFolder, FaRegUserCircle } from "react-icons/fa";
import ImageMod from "./components/ImageMod.astro";
const { default_language } = config.settings;

const COLLECTION_FOLDER = "blog";
const { post } = Astro.props;
let { lang } = Astro.params;

if (!lang) {
  lang = default_language;
}

const posts = await getSinglePage(
  COLLECTION_FOLDER,
  lang as keyof ContentEntryMap
);
const similarPosts = similarItems(post, posts);
const { Content } = await render(post);
const { title, description, author, categories, image, date, tags } = post.data;
---

<section class="section pt-7">
  <div class="container">
    <div class="row justify-center">
      <article class="lg:col-10">
        {
          image && (
            <div class="mb-10">
              <ImageMod
                src={image}
                height={500}
                width={1200}
                alt={title}
                class="w-full rounded"
                format="webp"
              />
            </div>
          )
        }
        <h1 set:html={markdownify(title)} class="h2 mb-4" />
        <ul class="mb-4">
          <li class="mr-4 inline-block">
            <a href={slugSelector(`/authors/${slugify(author)}`, lang)}>
              <FaRegUserCircle className={"mr-2 -mt-1 inline-block"} />
              {humanize(author)}
            </a>
          </li>
          <li class="mr-4 inline-block">
            <FaRegFolder className={"mr-2 -mt-1 inline-block"} />
            {
              categories.map((category: string, index: number) => (
                <a
                  href={slugSelector(`/categories/${slugify(category)}`, lang)}
                >
                  {humanize(category)}
                  {index !== categories.length - 1 && ","}
                </a>
              ))
            }
          </li>
          <li class="mr-4 inline-block">
            <FaRegClock className={"mr-2 -mt-1 inline-block"} />
            {dateFormat(date)}
          </li>
        </ul>
        <div class="content mb-10">
          <Content />
        </div>
        <div class="row items-start justify-between">
          <div class="mb-10 flex items-center lg:col-5 lg:mb-0">
            <h5 class="mr-3">Tags :</h5>
            <ul>
              {
                tags.map((tag: string) => (
                  <li class="inline-block">
                    <a
                      class="m-1 block rounded bg-light px-3 py-1 hover:bg-primary hover:text-white dark:bg-darkmode-light dark:hover:bg-darkmode-primary dark:hover:text-text-dark"
                      href={slugSelector(`/tags/${slugify(tag)}`, lang)}
                    >
                      {humanize(tag)}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="flex items-center lg:col-4">
            <h5 class="mr-3">Share :</h5>
            <Share
              className="social-icons"
              title={title}
              description={description}
              slug={post.id}
            />
          </div>
        </div>
        <Disqus className="mt-20" client:load />
      </article>
    </div>

    <!-- Related posts -->
    <div class="section pb-0">
      <h2 class="h3 mb-12 text-center">Related Posts</h2>
      <div class="row justify-center">
        {
          similarPosts.map((post) => (
            <div class="lg:col-4 md:col-6 mb-14">
              <BlogCard data={post} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  
  /* Layout control specifically for tables in the article body */
  .content table {
    display: table !important;
    width: 100% !important;
    /* Core: 'auto' mode allows columns to squeeze intelligently based on content ratio */
    table-layout: auto !important;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  /* Treat all columns equally, distributing space evenly by default */
  .content table th,
  .content table td {
    border: 1px solid #e5e7eb;
    padding: 12px 16px;
    vertical-align: top;
    /* 1. Set an equal width target for each column */
    width: 1%;
    /* 2. Combined with this property, let content dictate actual width for automatic squeezing */
    white-space: normal;
    /* 3. Allow long content to wrap, preventing layout overflow */
    word-break: break-word;
  }

  /* Adapt border colors for Dark Mode to maintain visual consistency */
  .dark .content table td,
  .dark .content table th {
    border-color: #374151;
  }

  /* Eliminate quotes automatically generated by Tailwind Typography */
  .content blockquote p::before,
  .content blockquote p::after {
    content: "" !important;
  }

  /* Compatibility for specific plugin styles */
  .content blockquote {
    quotes: none !important;
  }

  /* Styles for inline code ` ` within the article body */
  .content :not(pre) > code {
    /* Light Mode: Gray background with dark text */
    background-color: #f3f4f6 !important; /* Light gray background (Gray 100) */
    color: #1f2937 !important;            /* Dark gray/Black text (Gray 800) */
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
  }

  /* Inline code styles for Dark Mode */
  .dark .content :not(pre) > code {
    /* Dark Mode: Dark gray background with white text */
    background-color: #374151 !important; /* Dark gray background (Gray 700) */
    color: #f9fafb !important;            /* Near-white text (Gray 50) */
  }

  /* Remove automatically generated backticks (if any) */
  .content :not(pre) > code::before,
  .content :not(pre) > code::after {
    content: "" !important;
  }
</style>