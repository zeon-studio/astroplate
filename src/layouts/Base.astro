---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import theme from "@/config/theme.json";
import { siteConfig } from "@/lib/siteConfig";
import { getLocaleAlternates } from "@/lib/utils/localeAlternates";
import { getLangFromUrl, getTranslations } from "@/lib/utils/languageParser";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";
import { Font } from "astro:assets";
import Announcement from "./helpers/Announcement";
import SearchModal from "./helpers/SearchModal";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  og_type?: "website" | "article";
  lang?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  articlePublishedTime?: Date | string;
  articleModifiedTime?: Date | string;
  articleSection?: string;
  articleTags?: string[];
  articleAuthor?: string;
}

// destructure frontmatter
const {
  title,
  meta_title,
  description,
  image,
  noindex,
  canonical,
  og_type,
  lang,
  jsonLd,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags = [],
  articleAuthor,
} = Astro.props;

const language = lang || getLangFromUrl(Astro.url);
const siteUrl =
  Astro.site ||
  (siteConfig.site.base_url ? new URL(siteConfig.site.base_url) : undefined);
const seoTitle = plainify(
  meta_title ? meta_title : title ? title : siteConfig.site.title,
).trim();
const seoDescription = plainify(
  description ? description : siteConfig.metadata.meta_description,
).trim();
const canonicalUrl = siteUrl
  ? canonical
    ? new URL(canonical, siteUrl).toString()
    : new URL(Astro.url.pathname, siteUrl).toString()
  : canonical;
const socialImage = siteUrl
  ? new URL(image ? image : siteConfig.metadata.meta_image, siteUrl).toString()
  : image || siteConfig.metadata.meta_image;
const ogType = og_type || "website";
const siteRootUrl = siteUrl ? new URL("/", siteUrl).toString() : undefined;
const organizationId = siteRootUrl ? `${siteRootUrl}#organization` : undefined;
const websiteId = siteRootUrl ? `${siteRootUrl}#website` : undefined;
const toISOString = (value?: Date | string) =>
  value instanceof Date ? value.toISOString() : value;
const publishedTime = toISOString(articlePublishedTime);
const modifiedTime = toISOString(articleModifiedTime);
const searchStrings = (await getTranslations(language)) as Record<
  string,
  string
>;
const shouldEmitAlternates =
  !noindex && Astro.url.pathname !== "/404" && Boolean(siteUrl);
const localeAlternates = shouldEmitAlternates
  ? await getLocaleAlternates(Astro.url.pathname)
  : undefined;
const alternateUrls =
  siteUrl &&
  localeAlternates &&
  Object.keys(localeAlternates.alternates).length > 1
    ? Object.entries(localeAlternates.alternates).map(([locale, path]) => ({
        locale,
        href: new URL(path, siteUrl).toString(),
      }))
    : [];
const xDefaultUrl =
  siteUrl && localeAlternates?.defaultPath && alternateUrls.length > 1
    ? new URL(localeAlternates.defaultPath, siteUrl).toString()
    : undefined;
const suppliedJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const jsonLdGraph = siteRootUrl
  ? [
      {
        "@type": "Organization",
        "@id": organizationId,
        name: siteConfig.metadata.meta_author || siteConfig.site.title,
        url: siteRootUrl,
        logo: new URL(siteConfig.site.logo, siteRootUrl).toString(),
      },
      {
        "@type": "WebSite",
        "@id": websiteId,
        url: siteRootUrl,
        name: siteConfig.site.title,
        description: siteConfig.metadata.meta_description,
        inLanguage: language,
        publisher: { "@id": organizationId },
      },
      ...suppliedJsonLd,
    ]
  : suppliedJsonLd;
const structuredData =
  jsonLdGraph.length > 0
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@graph": jsonLdGraph,
      })
    : undefined;
---

<!doctype html>
<html lang={language}>
  <head>
    <!-- google tag manager -->
    {
      siteConfig.google_tag_manager.enable && (
        <GoogleTagmanager id={siteConfig.google_tag_manager.gtm_id} />
      )
    }
    <!-- favicon -->
    <link rel="shortcut icon" href={siteConfig.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="astroplate" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css - Astro 6 built-in Font API -->
    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>{seoTitle}</title>

    <!-- canonical url -->
    {
      canonicalUrl && (
        <link rel="canonical" href={canonicalUrl} item-prop="url" />
      )
    }
    {
      alternateUrls.map(({ locale, href }) => (
        <link rel="alternate" hreflang={locale} href={href} />
      ))
    }
    {
      xDefaultUrl && (
        <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
      )
    }

    <!-- noindex robots -->
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta name="description" content={seoDescription} />

    <!-- author from config.json -->
    <meta name="author" content={siteConfig.metadata.meta_author} />

    <!-- og-title -->
    <meta property="og:title" content={seoTitle} />

    <!-- og-description -->
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content={siteConfig.site.title} />
    <meta property="og:locale" content={language} />
    {
      ogType === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === "article" && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }
    {
      ogType === "article" && articleAuthor && (
        <meta property="article:author" content={articleAuthor} />
      )
    }
    {
      ogType === "article" && articleSection && (
        <meta property="article:section" content={articleSection} />
      )
    }
    {
      ogType === "article" &&
        articleTags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))
    }

    <!-- twitter-title -->
    <meta name="twitter:title" content={seoTitle} />

    <!-- twitter-description -->
    <meta name="twitter:description" content={seoDescription} />

    <!-- og-image -->
    <meta property="og:image" content={socialImage} />

    <!-- twitter-image -->
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      structuredData && (
        <script
          is:inline
          type="application/ld+json"
          set:html={structuredData}
        />
      )
    }
  </head>
  <body class="flex flex-col min-h-screen">
    {/* google tag manager noscript */}
    {
      siteConfig.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={siteConfig.google_tag_manager.gtm_id} />
      )
    }
    {siteConfig.announcement.enable && <Announcement client:only="react" />}
    <Header />
    {
      siteConfig.settings.search && (
        <SearchModal
          lang={language}
          searchPlaceholder={searchStrings.search_placeholder}
          searchEmpty={searchStrings.search_empty}
          searchResultsLabel={searchStrings.search_results}
          searchSecondsLabel={searchStrings.search_seconds}
          searchNavigateLabel={searchStrings.search_to_navigate}
          searchSelectLabel={searchStrings.search_to_select}
          searchCloseLabel={searchStrings.search_to_close}
          client:only="react"
        />
      )
    }
    <main class="grow" id="main-content">
      <slot />
    </main>
    <Footer />
    <TwSizeIndicator />
  </body>
</html>
