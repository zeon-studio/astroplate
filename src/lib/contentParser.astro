---
import {
  getCollection,
  getEntry,
  type CollectionEntry,
  type CollectionKey,
} from "astro:content";
import { getContentDir } from "@/lib/utils/languageParser";

type PageData = {
  title: string;
  meta_title?: string;
  description?: string;
  image?: string;
  draft?: boolean;
};

export const getSinglePage = async <C extends CollectionKey>(
  collectionName: C,
  lang?: string,
  subCollectionName?: string,
): Promise<CollectionEntry<C>[]> => {
  const contentDir = getContentDir(lang);
  const contentPath = subCollectionName
    ? `${contentDir}/${subCollectionName}`
    : contentDir;

  const allPages = await getCollection(
    collectionName,
    ({ data, id }) => !(data as PageData)?.draft && !id.startsWith("-")
  );

  return allPages.filter(({ id }) => {
    const entryName = id.split("/").pop() || "";
    return id.startsWith(contentPath) && !entryName.startsWith("-");
  });
};

export const getListPage = async <C extends CollectionKey>(
  collectionName: C,
  lang?: string,
  documentId: "-index" | string = "-index",
): Promise<CollectionEntry<C>> => {
  const contentDir = getContentDir(lang);
  const data = (await getEntry(
    collectionName,
    `${contentDir}/${documentId}`
  )) as CollectionEntry<C> | null;

  if (!data) {
    throw new Error(
      `No page found for the collection: ${collectionName} with filename: ${documentId}`
    );
  }

  return data;
};
---
