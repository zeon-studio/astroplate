{
  "version": "1",
  "settings": {
    "title": "Astroplate",
    "tagline": "astro and tailwind boilerplate",
    "url": "https://astroplate.netlify.app",
    "postsPerPage": 2,
    "dateFormat": "MMMM d, yyyy",
    "social": {
      "facebook": "https://www.facebook.com/",
      "twitter": "https://x.com/",
      "github": "https://www.github.com/",
      "linkedin": "https://www.linkedin.com/"
    }
  },
  "collections": [
    {
      "slug": "posts",
      "label": "Posts",
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true
        },
        {
          "slug": "slug",
          "label": "Slug",
          "type": "slug",
          "source": "title",
          "required": true,
          "unique": true
        },
        {
          "slug": "status",
          "label": "Status",
          "type": "select",
          "required": true,
          "defaultValue": "draft",
          "validation": { "options": ["published", "draft"] }
        },
        { "slug": "published_at", "label": "Published At", "type": "datetime" },
        { "slug": "meta_title", "label": "Meta Title", "type": "string" },
        {
          "slug": "description",
          "label": "Description",
          "type": "text",
          "options": { "rows": 2 }
        },
        {
          "slug": "excerpt",
          "label": "Excerpt",
          "type": "text",
          "options": { "rows": 3 }
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image"
        },
        { "slug": "content", "label": "Content", "type": "portableText" },
        {
          "slug": "author",
          "label": "Author",
          "type": "string",
          "defaultValue": "Admin"
        },
        { "slug": "categories", "label": "Categories", "type": "json" },
        { "slug": "tags", "label": "Tags", "type": "json" }
      ]
    },
    {
      "slug": "pages",
      "label": "Pages",
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true
        },
        {
          "slug": "slug",
          "label": "Slug",
          "type": "slug",
          "source": "title",
          "required": true,
          "unique": true
        },
        { "slug": "meta_title", "label": "Meta Title", "type": "string" },
        {
          "slug": "description",
          "label": "Description",
          "type": "text",
          "options": { "rows": 2 }
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image"
        },
        { "slug": "content", "label": "Content", "type": "portableText" }
      ]
    }
  ],
  "menus": [
    {
      "name": "main",
      "label": "Main Navigation",
      "items": [
        { "type": "custom", "label": "Home", "url": "/" },
        { "type": "custom", "label": "About", "url": "/about" },
        { "type": "custom", "label": "Elements", "url": "/elements" },
        {
          "type": "custom",
          "label": "Pages",
          "url": "#",
          "children": [
            { "type": "custom", "label": "Contact", "url": "/contact" },
            { "type": "custom", "label": "Blog", "url": "/blog" },
            { "type": "custom", "label": "Authors", "url": "/authors" },
            { "type": "custom", "label": "Categories", "url": "/categories" },
            { "type": "custom", "label": "Tags", "url": "/tags" },
            { "type": "custom", "label": "404 Page", "url": "/404" }
          ]
        }
      ]
    },
    {
      "name": "footer",
      "label": "Footer Navigation",
      "items": [
        { "type": "custom", "label": "Elements", "url": "/elements" },
        {
          "type": "custom",
          "label": "Privacy Policy",
          "url": "/privacy-policy"
        }
      ]
    }
  ]
}
